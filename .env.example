# ── Pierics environment ─────────────────────────────────────────────
# Copy to .env and fill in. The server boots without these (serving
# /api/plans and the cost estimator), but auth/billing/usage need them.

# JWT signing secret (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Stripe TEST mode keys (Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price ID for the $50/mo Pro subscription (Products → Pro → API ID)
STRIPE_PRO_PRICE_ID=price_xxx

# Public app URL used for Stripe redirect URLs
APP_URL=http://localhost:5173

# Server port (local dev)
PORT=3000

# ── Gateway (the core product) ──────────────────────────────────────
# Pierics' OWN provider accounts — all user traffic flows through these and
# spends real money. Groq has a free tier; OpenAI needs funded credit.
GROQ_API_KEY=gsk_xxx
OPENAI_API_KEY=sk-xxx

# Optional: hard month-to-date spend ceiling (base provider cost, USD). When
# month-to-date base_cost ≥ this, the gateway returns 503 budget_exceeded.
GATEWAY_MONTHLY_BUDGET_USD=

# Optional cost-saver: 1 = serve the `quality` tier as gpt-4o-mini (~16x
# cheaper) at its real price. Remove (and redeploy) before launch for GPT-4o.
DEMO_BUDGET_MODE=

# Optional: per-minute rate limiting (correct limiting needs an external store
# on serverless). Without these, the per-minute limit is skipped (logged).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
